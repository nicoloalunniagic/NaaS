{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "westeurope"
    },
    "namePrefix": {
      "value": "naasprod01"
    },
    "containerImage": {
      "value": "naasprod01acr.azurecr.io/naas:latest"
    },
    "containerCpu": {
      "value": "0.5"
    },
    "containerMemory": {
      "value": "1.0Gi"
    },
    "minReplicas": {
      "value": 2
    },
    "maxReplicas": {
      "value": 5
    },
    "deployAppInsights": {
      "value": true
    }
  }
}
