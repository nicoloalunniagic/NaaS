{
	"info": {
		"name": "No-as-a-Service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"devuser\",\n  \"password\": \"DevPassword123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/auth/register"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"devuser\",\n  \"password\": \"DevPassword123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/auth/login"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"let data = {};",
									"try {",
									"  data = pm.response.json();",
									"} catch (e) {",
									"  data = {};",
									"}",
									"if (data.token) {",
									"  pm.environment.set('authToken', data.token);",
									"  pm.test('authToken saved', function () {",
									"    pm.expect(pm.environment.get('authToken')).to.eql(data.token);",
									"  });",
									"} else {",
									"  pm.test('login response contains token', function () {",
									"    pm.expect(data.token, 'token missing in login response').to.be.a('string').and.not.empty;",
									"  });",
									"}"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Core",
			"item": [
				{
					"name": "Get Service Info",
					"request": {
						"method": "GET",
						"header": [],
